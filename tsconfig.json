{
  "extends": "./common/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "@common/*": [
        "./common/*"
      ],
    },
    "composite": false,
    // "types": [
    //   "preact",
    //   "node",
    // ],
    "jsx": "react",
    "jsxFactory": "h",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules",
    ],
  },
  "include": ["**/*"],
}
